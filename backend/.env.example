# Server
PORT=5004
NODE_ENV=development

# Database
# Use MONGO_URI or MONGODB_URI. MONGO_URI matches the current backend code.
MONGO_URI=mongodb://localhost:27017/aurex

# Auth
# Replace this with a long random secret in production.
JWT_SECRET_KEY=replace-with-a-secure-random-secret

# CORS
# For one frontend:
FRONTEND_URL=http://localhost:3000
# For multiple frontends, use comma-separated origins:
# CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
